# Theming
config-file = ~/.local/state/quickshell/user/generated/terminal/ghostty-theme.conf

# Font
font-family = JetBrains Mono Nerd Font
font-size = 11

# Cursor
cursor-style = bar
cursor-style-blink = true

# Padding
window-padding-x = 21
window-padding-y = 21

# Touch scroll sensitivity (too fast by default)
mouse-scroll-multiplier = precision:0.3

# Pass Super+Q through to Hyprland (close window) instead of Ghostty consuming it
keybind = super+q=ignore

# Use zsh shell
command = zsh
