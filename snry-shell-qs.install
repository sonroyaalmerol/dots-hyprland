post_install() {
	# Create snry-dm system user for the display manager greeter.
	if ! id -u snry-dm &>/dev/null; then
		useradd -r -M -d /var/lib/snry-dm -s /bin/false snry-dm
		mkdir -p /var/lib/snry-dm/.config
		chown -R snry-dm:snry-dm /var/lib/snry-dm
	fi

	# Install PAM config.
	if [ ! -f /etc/pam.d/snry-dm ]; then
		cp /usr/share/snry-shell/configs/pam/snry-dm /etc/pam.d/snry-dm
	fi

	# Detect the installing user (not root)
	local user
	user=$(logname 2>/dev/null || awk -F: '$3>=1000 && $3<65534 {print $1; exit}' /etc/passwd)

	if [ -z "$user" ]; then
		echo ">>> Could not detect installing user. Run 'snry-daemon setup' manually."
		return 0
	fi

	local uid
	uid=$(id -u "$user")

	echo ">>> Setting up Snry Shell for user: $user"

	# Phase 1: System setup (we are root — groups, services, PAM, logind)
	HOME="/home/$user" snry-daemon setups 2>/dev/null || true

	# Phase 2: Config sync + daemon binary (as the user)
	sudo -u "$user" HOME="/home/$user" XDG_RUNTIME_DIR="/run/user/$uid" \
		snry-daemon files 2>/dev/null || true

	# Phase 3: Enable and start the daemon via systemd user service
	sudo -u "$user" XDG_RUNTIME_DIR="/run/user/$uid" \
		systemctl --user enable --now snry-daemon.service 2>/dev/null || true

	echo ""
	echo ">>> Snry Shell installed and configured!"
	echo ">>> Log out and log back in (or reboot) to start."
	echo ""
	echo ">>> To enable the display manager (replaces your login screen):"
	echo ">>>   sudo systemctl enable snry-dm.service"
	echo ">>>   sudo systemctl start snry-dm.service"
}

post_upgrade() {
	local user
	user=$(logname 2>/dev/null || awk -F: '$3>=1000 && $3<65534 {print $1; exit}' /etc/passwd)

	if [ -z "$user" ]; then
		echo ">>> Could not detect installing user. Run 'snry-daemon setup' manually."
		return 0
	fi

	local uid
	uid=$(id -u "$user")

	echo ">>> Syncing Snry Shell configs for user: $user"

	sudo -u "$user" HOME="/home/$user" XDG_RUNTIME_DIR="/run/user/$uid" \
		snry-daemon files 2>/dev/null || true

	# Restart the daemon to pick up any changes
	sudo -u "$user" XDG_RUNTIME_DIR="/run/user/$uid" \
		systemctl --user restart snry-daemon.service 2>/dev/null || true

	echo ""
	echo ">>> Snry Shell updated!"
	echo ">>> The daemon has been restarted via systemd."
}

post_remove() {
	local user
	user=$(logname 2>/dev/null || awk -F: '$3>=1000 && $3<65534 {print $1; exit}' /etc/passwd)

	if [ -z "$user" ]; then
		echo ">>> Could not detect installing user."
		echo ">>> Disable the service manually: systemctl --user disable --now snry-daemon.service"
		return 0
	fi

	local uid
	uid=$(id -u "$user")

	# Stop and disable the daemon service
	sudo -u "$user" XDG_RUNTIME_DIR="/run/user/$uid" \
		systemctl --user disable --now snry-daemon.service 2>/dev/null || true

	echo ""
	echo ">>> Snry Shell has been removed."
	echo ">>> Config files in ~/.config/ were NOT deleted."
	echo ">>> To fully clean up, run (before removing this package):"
	echo ">>>   snry-daemon uninstall"

	# Remove the DM user and PAM config.
	if id -u snry-dm &>/dev/null; then
		userdel snry-dm 2>/dev/null || true
	fi
	rm -f /etc/pam.d/snry-dm
	rm -rf /var/lib/snry-dm

	echo ""
}