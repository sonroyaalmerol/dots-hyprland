# Theming
config-file = ~/.local/state/quickshell/user/generated/terminal/ghostty-theme.conf

# Font
font-family = JetBrains Mono Nerd Font
font-size = 11

# Cursor
cursor-style = bar
cursor-style-blink = true

# Padding
window-padding-x = 21
window-padding-y = 21

# No close confirmation
confirm-before-close = false

# Use bash shell
command = bash
