# Theming
config-file = ~/.local/state/quickshell/user/generated/terminal/ghostty-theme.conf

# Font
font-family = JetBrains Mono Nerd Font
font-size = 11

# Cursor
cursor-style = bar
cursor-style-blink = true

# Padding
window-padding-x = 21
window-padding-y = 21

# Let Hyprland handle Super+Q (close window) instead of Ghostty intercepting it
keybind = super+q=unbind

# Use zsh shell
command = zsh
